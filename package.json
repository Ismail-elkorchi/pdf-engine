{
  "name": "@ismail-elkorchi/pdf-engine",
  "version": "0.1.0",
  "description": "Evidence-driven cross-runtime PDF parsing, reading, viewing, and extraction engine.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ismail-elkorchi/pdf-engine.git"
  },
  "homepage": "https://github.com/Ismail-elkorchi/pdf-engine#readme",
  "bugs": {
    "url": "https://github.com/Ismail-elkorchi/pdf-engine/issues"
  },
  "packageManager": "npm@11.8.0",
  "keywords": [
    "pdf",
    "parser",
    "reader",
    "rendering",
    "extraction",
    "typescript",
    "jsr",
    "npm"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src jsr scripts eslint.config.mjs --max-warnings=0",
    "lint:fix": "eslint src jsr scripts eslint.config.mjs --fix --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:runtimes": "node scripts/verify-runtime-versions.mjs",
    "verify:runtimes:pinned": "node scripts/verify-runtime-versions.mjs --mode=pinned",
    "runtime:staleness": "node scripts/runtime-staleness-check.mjs",
    "docs:lint:jsr": "deno doc --lint jsr/mod.ts",
    "docs:test:jsr": "deno test --doc --no-check jsr/mod.ts",
    "docs:check:jsr": "npm run docs:lint:jsr && npm run docs:test:jsr",
    "check": "npm run lint && npm run typecheck && npm run verify:runtimes && npm run docs:check:jsr",
    "deps:freshness": "node scripts/check-dependency-freshness.mjs",
    "test:fuzz": "npm run build && node scripts/fuzz/run-fuzz.mjs",
    "smoke:web": "node scripts/smoke/web-bundle.mjs",
    "smoke:compiled:node": "node scripts/smoke/runtime-smoke.mjs ../../dist/index.js node",
    "smoke:compiled:bun": "bun scripts/smoke/runtime-smoke.mjs ../../dist/index.js bun",
    "smoke:node": "npm run build && npm run smoke:compiled:node",
    "smoke:deno": "deno run --allow-read=./jsr,./src scripts/smoke/runtime-smoke.mjs ../../jsr/mod.ts deno",
    "smoke:bun": "npm run build && npm run smoke:compiled:bun",
    "smoke:all": "npm run build && npm run smoke:compiled:node && npm run smoke:deno && npm run smoke:compiled:bun && npm run smoke:web",
    "check:ci": "npm run check && npm run smoke:all && npm run test:fuzz"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-regexp": "^3.1.0",
    "fast-check": "^4.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.0"
  }
}
